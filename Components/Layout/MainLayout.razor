@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject MatchTrackerService Tracker

<MudThemeProvider Theme="@_darkTheme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Default" Class="top-appbar">
        <MudText Typo="Typo.h6">Match Tracker</MudText>
        <MudSpacer />
        <MudButton Class="top-nav-link" Variant="Variant.Text" Color="Color.Inherit" Href="/">
            Overview
        </MudButton>
        <MudButton Class="top-nav-link" Variant="Variant.Text" Color="Color.Inherit" Href="/players">
            Players
        </MudButton>
        <MudButton Class="top-nav-link" Variant="Variant.Text" Color="Color.Inherit" Href="/matches">
            Matches
        </MudButton>
        <MudButton Class="top-nav-link" Variant="Variant.Text" Color="Color.Inherit" Href="/tournament">
            Tournament
        </MudButton>
        <MudMenu Icon="@Icons.Material.Filled.MoreVert" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
            <MudMenuItem Icon="@Icons.Material.Filled.Settings" OnClick="TogglePointsUsageAsync">
                @($"Use PT: {(IsPointsEnabled ? "On" : "Off")}")
            </MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.Download" OnClick="ExportDataAsync">
                Export Data
            </MudMenuItem>
            <MudMenuItem Icon="@Icons.Material.Filled.UploadFile" OnClick="ImportDataAsync">
                Import Data
            </MudMenuItem>
        </MudMenu>
    </MudAppBar>

    <MudMainContent>
        <MudContainer Class="main-content" MaxWidth="MaxWidth.Large">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private const string ExportFileName = "match-tracker-data.json";
    private bool _isInitialized;
    private static readonly MudTheme _darkTheme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#6AA9D6",
            Secondary = "#E6A96B",
            Background = "#0F172A",
            Surface = "#162033",
            AppbarBackground = "#1A2940",
            AppbarText = "#E2E8F0",
            DrawerBackground = "#0B1220",
            DrawerText = "#CBD5E1",
            DrawerIcon = "#94A3B8",
            TextPrimary = "#E2E8F0",
            TextSecondary = "#94A3B8",
            LinesDefault = "rgba(148, 163, 184, 0.24)",
            Success = "#22C55E",
            Warning = "#F59E0B",
            Error = "#EF4444",
            Info = "#38BDF8"
        }
    };
    private bool IsPointsEnabled => Tracker.IsPointsEnabled();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Tracker.EnsureInitializedAsync(JS);
        _isInitialized = true;
        StateHasChanged();
    }

    private async Task TogglePointsUsageAsync(MouseEventArgs _)
    {
        if (!_isInitialized)
        {
            await Tracker.EnsureInitializedAsync(JS);
            _isInitialized = true;
        }

        var usePoints = !Tracker.IsPointsEnabled();
        if (!Tracker.SetPointsEnabled(usePoints))
        {
            return;
        }

        await Tracker.PersistAsync(JS);
        Snackbar.Add(usePoints ? "PT enabled." : "PT disabled.", Severity.Info);
    }

    private async Task ExportDataAsync(MouseEventArgs _)
    {
        await Tracker.EnsureInitializedAsync(JS);

        var payload = Tracker.ExportStateJson();
        await JS.InvokeVoidAsync("matchTrackerInterop.downloadJsonFile", ExportFileName, payload);
        Snackbar.Add("Data exported.", Severity.Success);
    }

    private async Task ImportDataAsync(MouseEventArgs _)
    {
        await Tracker.EnsureInitializedAsync(JS);

        var importedPayload = await JS.InvokeAsync<string?>("matchTrackerInterop.pickJsonFile");
        if (string.IsNullOrWhiteSpace(importedPayload))
        {
            return;
        }

        if (!Tracker.TryImportStateJson(importedPayload, out var errorMessage))
        {
            Snackbar.Add(errorMessage, Severity.Error);
            return;
        }

        await Tracker.PersistAsync(JS);
        Snackbar.Add("Data imported.", Severity.Success);
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }
}
