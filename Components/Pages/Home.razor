@page "/"
@implements IDisposable

@inject MatchTrackerService Tracker
@inject IJSRuntime JS

<PageTitle>Overview</PageTitle>

<MudStack Spacing="3">
	<MudText Typo="Typo.h3" Align="Align.Center">Scores</MudText>

	@if (!_isReady)
	{
		<MudStack Row="true" Justify="Justify.Center" Class="mt-6">
			<MudProgressCircular Color="Color.Primary" Indeterminate="true" />
		</MudStack>
	}
	else if (SummaryRows.Count == 0)
	{
		<MudAlert Severity="Severity.Info" Dense="true">
			No players yet. Add players first, then start tracking matches.
		</MudAlert>
	}
	else
	{
		var rows = SummaryRows.ToList();

		@if (rows.Count >= 3)
		{
			<MudGrid Justify="Justify.Center">
				@for (int i = 0; i < 3; i++)
				{
					var player = i switch
					{
						0 => rows[1],
						1 => rows[0],
						2 => rows[2]
					};

					int minHeight = i switch
					{
						0 => 375,
						1 => 400,
						2 => 360,
					};

					string color = i switch
					{
						0 => "#C0C0C0", // silver
						1 => "#FFD700", // gold
						2 => "#CD7F32", // bronze
					};

					string medalSrc = i switch
					{
						0 => "/Images/SilverMedal.png",
						1 => "/Images/Trophy.png",
						2 => "/Images/BronzeMedal.png",
					};

					<MudItem xs="3" Class="d-flex" Style="align-items:end;">
						<MudPaper MinHeight=@($"{minHeight}px") Class="player-cell pa-4 border-solid border-2" Style=@($"border-color:{color};") Elevation="2">
							<MudStack AlignItems="AlignItems.Center">
								<MudImage Src="@medalSrc" Elevation="0" Class="rounded-lg" />
							</MudStack>

							<div style="height:20px" />

							<MudStack AlignItems="AlignItems.Center">
								<MudText Typo="Typo.h4" Class="player-name" Align="Align.Center">@player.Name</MudText>
								<MudSpacer />
								<MudChip Variant="Variant.Filled" T="string">@player.WinRateLabel</MudChip>
								@if (IsPointsEnabled)
								{
									<MudChip Variant="Variant.Filled" Color="Color.Info" Class="player-cell-score" T="string">@($"{player.Score} PT")</MudChip>
								}
							</MudStack>
							<MudDivider Class="my-2" />
							<MudGrid Justify="Justify.Center">
								<MudItem>
									<MudStack>
										<MudText Align="Align.Center" Typo="Typo.body2">Wins</MudText>
										<MudAvatar Color="Color.Success" Size="Size.Large" Class="stat-value">@player.Wins</MudAvatar>
									</MudStack>
								</MudItem>
								<MudItem>
									<MudStack>
										<MudText Align="Align.Center" Typo="Typo.body2">Losses</MudText>
										<MudAvatar Color="Color.Error" Size="Size.Large" Class="stat-value">@player.Losses</MudAvatar>
									</MudStack>
								</MudItem>
								<MudItem>
									<MudStack>
										<MudText Align="Align.Center" Typo="Typo.body2">Draws</MudText>
										<MudAvatar Color="Color.Warning" Size="Size.Large" Class="stat-value">@player.Draws</MudAvatar>
									</MudStack>
								</MudItem>
							</MudGrid>
						</MudPaper>
					</MudItem>
				}
			</MudGrid>
		}

		<MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-2">
			<MudSelect T="OverviewSortMode"
					   Label="Sort by"
					   Variant="Variant.Outlined"
					   Margin="Margin.Dense"
					   Dense="true"
					   @bind-Value="_sortMode">
				<MudSelectItem Value="@OverviewSortMode.Alphabetic">Alphabetic</MudSelectItem>
				<MudSelectItem Value="@OverviewSortMode.ByWinRate">By WR</MudSelectItem>
				<MudSelectItem Value="@OverviewSortMode.ByWins">By Wins</MudSelectItem>
				@if (IsPointsEnabled)
				{
					<MudSelectItem Value="@OverviewSortMode.ByPoints">By PT</MudSelectItem>
				}
			</MudSelect>
		</MudStack>

		<MudGrid Class="player-grid">
			@for (int i = rows.Count >= 3 ? 3 : 0; i < rows.Count; i++)
			{
				var player = rows[i];
				<MudItem xs="12" sm="6" md="4" lg="3">
					<MudPaper Class="player-cell pa-4" Elevation="2">
						<MudStack Row AlignItems="AlignItems.Center">
							<MudText Typo="Typo.h5" Class="player-name" Align="Align.Center">@player.Name</MudText>
							<MudSpacer />
							<MudChip Variant="Variant.Filled" T="string">@player.WinRateLabel</MudChip>
							@if (IsPointsEnabled)
							{
								<MudChip Variant="Variant.Filled" Color="Color.Info" Class="player-cell-score" T="string">@($"{player.Score} PT")</MudChip>
							}
						</MudStack>
						<MudDivider Class="my-2" />
						<MudGrid Justify="Justify.Center">
							<MudItem>
								<MudStack>
									<MudText Align="Align.Center" Typo="Typo.body2">Wins</MudText>
									<MudAvatar Color="Color.Success" Size="Size.Large" Class="stat-value">@player.Wins</MudAvatar>
								</MudStack>
							</MudItem>
							<MudItem>
								<MudStack>
									<MudText Align="Align.Center" Typo="Typo.body2">Losses</MudText>
									<MudAvatar Color="Color.Error" Size="Size.Large" Class="stat-value">@player.Losses</MudAvatar>
								</MudStack>
							</MudItem>
							<MudItem>
								<MudStack>
									<MudText Align="Align.Center" Typo="Typo.body2">Draws</MudText>
									<MudAvatar Color="Color.Warning" Size="Size.Large" Class="stat-value">@player.Draws</MudAvatar>
								</MudStack>
							</MudItem>
						</MudGrid>
					</MudPaper>
				</MudItem>
			}
		</MudGrid>
	}
</MudStack>

@code {
	private bool _isReady;
	private OverviewSortMode _sortMode = OverviewSortMode.ByPoints;
	private bool IsPointsEnabled => Tracker.IsPointsEnabled();

	protected override void OnInitialized()
	{
		Tracker.OptionsChanged += HandleOptionsChanged;
	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender)
		{
			return;
		}

		await Tracker.EnsureInitializedAsync(JS);
		if (!IsPointsEnabled && _sortMode == OverviewSortMode.ByPoints)
		{
			_sortMode = OverviewSortMode.ByWinRate;
		}

		_isReady = true;
		StateHasChanged();
	}

	private IReadOnlyList<PlayerSummary> SummaryRows
	{
		get
		{
			var summaries = Tracker.GetPlayerSummaries();
			var sortMode = _sortMode == OverviewSortMode.ByPoints && !IsPointsEnabled
				? OverviewSortMode.ByWinRate
				: _sortMode;

			return sortMode switch
			{
				OverviewSortMode.Alphabetic => summaries
					.OrderBy(summary => summary.Name, StringComparer.OrdinalIgnoreCase)
					.ThenBy(summary => summary.Name, StringComparer.Ordinal)
					.ToList(),
				OverviewSortMode.ByWinRate => (IsPointsEnabled
						? summaries.OrderByDescending(summary => summary.WinRate)
							.ThenByDescending(summary => summary.Score)
						: summaries.OrderByDescending(summary => summary.WinRate))
					.ThenByDescending(summary => summary.Wins)
					.ThenBy(summary => summary.Name, StringComparer.OrdinalIgnoreCase)
					.ToList(),
				OverviewSortMode.ByWins => summaries.OrderByDescending(summary => summary.Wins)
					.ThenBy(summary => summary.WinRate)
					.ThenBy(summary => summary.Name, StringComparer.OrdinalIgnoreCase)
					.ToList(),
				_ => summaries
					.OrderByDescending(summary => summary.Score)
					.ThenByDescending(summary => summary.WinRate)
					.ThenBy(summary => summary.Name, StringComparer.OrdinalIgnoreCase)
					.ToList()
			};
		}
	}

	public void Dispose()
	{
		Tracker.OptionsChanged -= HandleOptionsChanged;
	}

	private void HandleOptionsChanged()
	{
		if (!IsPointsEnabled && _sortMode == OverviewSortMode.ByPoints)
		{
			_sortMode = OverviewSortMode.ByWinRate;
		}

		_ = InvokeAsync(StateHasChanged);
	}

	private enum OverviewSortMode
	{
		Alphabetic,
		ByWinRate,
		ByPoints,
		ByWins,
	}
}
