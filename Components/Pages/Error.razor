@page "/Error"

<PageTitle>Error</PageTitle>

<MudStack Spacing="2">
    <MudAlert Severity="Severity.Error" Dense="true">
        An error occurred while processing your request.
    </MudAlert>

    <MudPaper Class="pa-4">
        <MudText Typo="Typo.body2">Reload the page and try again.</MudText>
    </MudPaper>
</MudStack>
