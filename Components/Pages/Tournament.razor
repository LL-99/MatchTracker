@page "/tournament"

@inject MatchTrackerService Tracker
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<PageTitle>Tournament</PageTitle>

<MudStack Spacing="3">
    <MudText Typo="Typo.h4">Tournament</MudText>

    @if (!_isReady)
    {
        <MudStack Row="true" Justify="Justify.Center" Class="mt-6">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </MudStack>
    }
    else
    {
        <MudPaper Class="pa-4">
            <MudGrid AlignItems="AlignItems.End">
                <MudItem xs="12" md="4">
                    <MudSelect T="TournamentMatchingMode"
                               Label="Matching mode"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               @bind-Value="_matchingMode">
                        <MudSelectItem Value="@TournamentMatchingMode.ClassicSwissStage">Classic Swiss Stage</MudSelectItem>
                        <MudSelectItem Value="@TournamentMatchingMode.MonradSwiss">Monrad Swiss</MudSelectItem>
                        <MudSelectItem Value="@TournamentMatchingMode.RoundRobin">Round Robin</MudSelectItem>
                        <MudSelectItem Value="@TournamentMatchingMode.Knockout">Knockout</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudSelect T="TournamentRankMetric"
                               Label="Seed players by"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               @bind-Value="_rankMetric">
                        <MudSelectItem Value="@TournamentRankMetric.WinRate">Win Rate</MudSelectItem>
                        <MudSelectItem Value="@TournamentRankMetric.TotalWins">Total Wins</MudSelectItem>
                        <MudSelectItem Value="@TournamentRankMetric.Points">Points</MudSelectItem>
                        <MudSelectItem Value="@TournamentRankMetric.Random">Random</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" md="4">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               OnClick="GenerateTournamentAsync">
                        Generate Tournament
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_currentTournament is null)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No active tournament yet. Click Generate Tournament to snapshot current player data.
            </MudAlert>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                Active tournament generated on @_currentTournament.GeneratedOnUtc.ToLocalTime().ToString("g")
                using @GetMatchingModeLabel(_currentTournament.MatchingMode) and @GetRankMetricLabel(_currentTournament.RankMetric).
                @if (_currentTournament.CompletedOnUtc.HasValue)
                {
                    <span> Completed on @_currentTournament.CompletedOnUtc.Value.ToLocalTime().ToString("g").</span>
                }
            </MudAlert>

            <MudStack Row="true" Justify="Justify.FlexEnd" Class="mb-2">
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Error"
                           OnClick="DiscardTournamentAsync">
                    Discard Tournament
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Warning"
                           OnClick="FinishTournamentAsync">
                    Finish Tournament
                </MudButton>
            </MudStack>

            <MudGrid>
                <MudItem xs="12" lg="7">
                    <MudText Typo="Typo.h6">Standings</MudText>
                    <MudTable T="TournamentStandingRow" Items="_standings" Hover="true" Dense="true">
                        <HeaderContent>
                            <MudTh>#</MudTh>
                            <MudTh>Player</MudTh>
                            <MudTh Style="text-align: right;">Points</MudTh>
                            <MudTh Style="text-align: right;">W</MudTh>
                            <MudTh Style="text-align: right;">L</MudTh>
                            <MudTh Style="text-align: right;">D</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="#">@context.Rank</MudTd>
                            <MudTd DataLabel="Player">@context.Name</MudTd>
                            <MudTd DataLabel="Points" Style="text-align: right;">@context.Points</MudTd>
                            <MudTd DataLabel="W" Style="text-align: right;">@context.Wins</MudTd>
                            <MudTd DataLabel="L" Style="text-align: right;">@context.Losses</MudTd>
                            <MudTd DataLabel="D" Style="text-align: right;">@context.Draws</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
                <MudItem xs="12" lg="5">
                    <MudText Typo="Typo.h6">Seeding Snapshot</MudText>
                    <MudTable T="TournamentSeedSnapshot" Items="_currentTournament.Seeds" Hover="true" Dense="true">
                        <HeaderContent>
                            <MudTh>Seed</MudTh>
                            <MudTh>Player</MudTh>
                            <MudTh Style="text-align: right;">Win Rate</MudTh>
                            <MudTh Style="text-align: right;">Wins</MudTh>
                            <MudTh Style="text-align: right;">Points</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Seed">@context.Seed</MudTd>
                            <MudTd DataLabel="Player">@context.Name</MudTd>
                            <MudTd DataLabel="Win Rate" Style="text-align: right;">@context.WinRateLabel</MudTd>
                            <MudTd DataLabel="Wins" Style="text-align: right;">@context.Wins</MudTd>
                            <MudTd DataLabel="Points" Style="text-align: right;">@context.Score</MudTd>
                        </RowTemplate>
                    </MudTable>
                </MudItem>
            </MudGrid>

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h6">Rounds</MudText>
                <MudTooltip Text="@(_newRoundDisabledReason ?? "Generate the next round from current standings.")">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="@(!_canGenerateNewRound)"
                               OnClick="GenerateNextRoundAsync">
                        New Round
                    </MudButton>
                </MudTooltip>
            </MudStack>
            @foreach (var round in _currentTournament.Rounds.OrderBy(round => round.RoundNumber))
            {
                <MudPaper Class="pa-4 tournament-round-card">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">@GetRoundDisplayLabel(_currentTournament, round)</MudText>
                    <MudGrid>
                        @foreach (var match in round.Matches.OrderBy(match => match.TableNumber))
                        {
                            <MudItem xs="12" md="6" lg="4">
                                <MudPaper Class="pa-3 tournament-match-card">
                                    <MudStack Spacing="1">
                                        @if (!string.IsNullOrWhiteSpace(match.MatchLabel))
                                        {
                                            <MudChip Color="Color.Secondary" Variant="Variant.Outlined" Size="Size.Small" T="string">
                                                @match.MatchLabel
                                            </MudChip>
                                        }
                                        <MudText Typo="Typo.caption">Match @match.TableNumber</MudText>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Class="pairing-row">
                                            @if (HasResolvedPlayerA(match))
                                            {
                                                <MudChip Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" T="string">
                                                    #@match.PlayerASeed
                                                </MudChip>
                                            }
                                            <MudText Typo="Typo.body1" Class="@(IsPlayerAWinner(match) ? "match-winner" : string.Empty)">
                                                @match.PlayerAName
                                            </MudText>
                                        </MudStack>

                                        @if (match.IsBye)
                                        {
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="pairing-row">
                                                <MudChip Color="Color.Warning" Variant="Variant.Filled" Size="Size.Small" T="string">BYE</MudChip>
                                                <MudText Typo="Typo.body2">Automatic win</MudText>
                                            </MudStack>
                                        }
                                        else if (!IsMatchReadyToPlay(match))
                                        {
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="pairing-row">
                                                @if (HasResolvedPlayerB(match))
                                                {
                                                    <MudChip Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" T="string">
                                                        #@match.PlayerBSeed
                                                    </MudChip>
                                                }
                                                <MudText Typo="Typo.body1">@GetPlayerBDisplayName(match)</MudText>
                                            </MudStack>

                                            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
                                                Waiting for previous knockout results.
                                            </MudAlert>
                                        }
                                        else
                                        {
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Class="pairing-row">
                                                @if (HasResolvedPlayerB(match))
                                                {
                                                    <MudChip Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" T="string">
                                                        #@match.PlayerBSeed
                                                    </MudChip>
                                                }
                                                <MudText Typo="Typo.body1" Class="@(IsPlayerBWinner(match) ? "match-winner" : string.Empty)">
                                                    @GetPlayerBDisplayName(match)
                                                </MudText>
                                            </MudStack>

                                            <MudStack Row="true" Spacing="1" Class="mt-2">
                                                <MudButton Variant="@(match.ResultForPlayerA == MatchResult.Win ? Variant.Filled : Variant.Outlined)"
                                                           Color="Color.Success"
                                                           Size="Size.Small"
                                                           OnClick="@(() => ReportResultAsync(round.RoundNumber, match.MatchId, MatchResult.Win))">
                                                    @match.PlayerAName Wins
                                                </MudButton>
                                                <MudButton Variant="@(match.ResultForPlayerA == MatchResult.Draw ? Variant.Filled : Variant.Outlined)"
                                                           Color="Color.Warning"
                                                           Size="Size.Small"
                                                           Disabled="@(_currentTournament.MatchingMode == TournamentMatchingMode.Knockout)"
                                                           Style="@(_currentTournament.MatchingMode == TournamentMatchingMode.Knockout ? "display:none;" : null)"
                                                           OnClick="@(() => ReportResultAsync(round.RoundNumber, match.MatchId, MatchResult.Draw))">
                                                    Draw
                                                </MudButton>
                                                <MudButton Variant="@(match.ResultForPlayerA == MatchResult.Loss ? Variant.Filled : Variant.Outlined)"
                                                           Color="Color.Error"
                                                           Size="Size.Small"
                                                           OnClick="@(() => ReportResultAsync(round.RoundNumber, match.MatchId, MatchResult.Loss))">
                                                    @match.PlayerBName Wins
                                                </MudButton>
                                            </MudStack>
                                        }

                                        <MudChip Color="@GetResultChipColor(match)" Variant="Variant.Outlined" Size="Size.Small" T="string" Class="mt-2">
                                            @GetResultLabel(match)
                                        </MudChip>
                                        @if (match.ReportedOnUtc.HasValue)
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                                Saved @match.ReportedOnUtc.Value.ToLocalTime().ToString("g")
                                            </MudText>
                                        }
                                    </MudStack>
                                </MudPaper>
                            </MudItem>
                        }
                    </MudGrid>
                </MudPaper>
            }
        }

        <MudText Typo="Typo.h6">Past Tournaments</MudText>
        @if (_history.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true">
                No archived tournaments yet.
            </MudAlert>
        }
        else
        {
            <MudTable T="TournamentHistorySummary"
                      Items="_history"
                      Hover="true"
                      Dense="true"
                      OnRowClick="HandleArchivedTournamentRowClick">
                <HeaderContent>
                    <MudTh>Mode</MudTh>
                    <MudTh>Metric</MudTh>
                    <MudTh Style="text-align: right;">Players</MudTh>
                    <MudTh Style="text-align: right;">Rounds</MudTh>
                    <MudTh Style="text-align: right;">Completed</MudTh>
                    <MudTh>Winner</MudTh>
                    <MudTh Style="text-align: right;">Generated</MudTh>
                    <MudTh Style="text-align: right;">Archived</MudTh>
                    <MudTh Style="text-align: right;"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Mode">@GetMatchingModeLabel(context.MatchingMode)</MudTd>
                    <MudTd DataLabel="Metric">@GetRankMetricLabel(context.RankMetric)</MudTd>
                    <MudTd DataLabel="Players" Style="text-align: right;">@context.PlayerCount</MudTd>
                    <MudTd DataLabel="Rounds" Style="text-align: right;">@context.TotalRounds</MudTd>
                    <MudTd DataLabel="Completed" Style="text-align: right;">@context.CompletedMatches/@context.TotalMatches</MudTd>
                    <MudTd DataLabel="Winner">@(context.WinnerName ?? "-")</MudTd>
                    <MudTd DataLabel="Generated" Style="text-align: right;">@context.GeneratedOnUtc.ToLocalTime().ToString("g")</MudTd>
                    <MudTd DataLabel="Archived" Style="text-align: right;">@context.ArchivedOnUtc.ToLocalTime().ToString("g")</MudTd>
                    <MudTd Style="text-align: right;">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => ConfirmDeleteArchivedTournamentAsync(context))"
                                       AriaLabel="Delete archived tournament" />
                    </MudTd>
                </RowTemplate>
                <ChildRowContent>
                    @if (_expandedArchivedTournamentIds.Contains(context.TournamentId))
                    {
                        <MudTr>
                            <td colspan="9" class="pa-0">
                                <MudPaper Class="pa-3 ma-2">
                                    @if (context.Rounds.Count == 0)
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            No archived round details are available for this tournament.
                                        </MudText>
                                    }
                                    else
                                    {
                                        @foreach (var round in context.Rounds.OrderBy(round => round.RoundNumber))
                                        {
                                            <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="1" Class="mb-2">
                                                <MudText Typo="Typo.subtitle2">Round @round.RoundNumber</MudText>
                                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                    @GetArchivedRoundSummary(round)
                                                </MudText>
                                            </MudStack>
                                        }

                                        <MudDivider Class="my-2" />
                                        <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="1">
                                            <MudText Typo="Typo.subtitle2">Final Scores</MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                @GetArchivedFinalScoreSummary(context)
                                            </MudText>
                                        </MudStack>
                                    }
                                </MudPaper>
                            </td>
                        </MudTr>
                    }
                </ChildRowContent>
            </MudTable>
        }
    }
</MudStack>

@code {
    private bool _isReady;
    private TournamentMatchingMode _matchingMode = TournamentMatchingMode.ClassicSwissStage;
    private TournamentRankMetric _rankMetric = TournamentRankMetric.WinRate;
    private TournamentSnapshot? _currentTournament;
    private List<TournamentStandingRow> _standings = new();
    private List<TournamentHistorySummary> _history = new();
    private HashSet<Guid> _expandedArchivedTournamentIds = new();
    private bool _canGenerateNewRound;
    private string? _newRoundDisabledReason;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        await Tracker.EnsureInitializedAsync(JS);
        LoadTournamentState();
        _isReady = true;
        StateHasChanged();
    }

    private void LoadTournamentState()
    {
        _currentTournament = Tracker.GetCurrentTournamentSnapshot();
        _history = Tracker.GetTournamentHistorySummaries().ToList();

        if (_currentTournament is not null)
        {
            _matchingMode = _currentTournament.MatchingMode;
            _rankMetric = _currentTournament.RankMetric;
            _standings = BuildStandings(_currentTournament);
            (_canGenerateNewRound, _newRoundDisabledReason) = EvaluateNewRoundAvailability(_currentTournament, _standings);
        }
        else
        {
            _standings = new List<TournamentStandingRow>();
            _canGenerateNewRound = false;
            _newRoundDisabledReason = null;
        }
    }

    private async Task GenerateTournamentAsync()
    {
        var seeded = GetSeededPlayers(_rankMetric).ToList();
        if (seeded.Count == 0)
        {
            Tracker.SetCurrentTournamentSnapshot(null);
            await Tracker.PersistAsync(JS);
            LoadTournamentState();
            Snackbar.Add("No players to seed. Active tournament cleared.", Severity.Info);
            return;
        }

        var generatedOnUtc = DateTime.UtcNow;
        var rounds = BuildRounds(_matchingMode, seeded, generatedOnUtc);
        if (rounds.Count == 0)
        {
            Snackbar.Add("Could not generate a tournament for this configuration.", Severity.Error);
            return;
        }

        Tracker.SetCurrentTournamentSnapshot(new TournamentSnapshot
        {
            TournamentId = Guid.NewGuid(),
            MatchingMode = _matchingMode,
            RankMetric = _rankMetric,
            GeneratedOnUtc = generatedOnUtc,
            CompletedOnUtc = null,
            Seeds = seeded,
            Rounds = rounds
        });

        await Tracker.PersistAsync(JS);
        LoadTournamentState();
        Snackbar.Add("Tournament generated and cached.", Severity.Success);
    }

    private async Task ReportResultAsync(int roundNumber, Guid tournamentMatchId, MatchResult resultForPlayerA)
    {
        if (_currentTournament is null)
        {
            return;
        }

        if (Tracker.TryRecordTournamentMatchResult(_currentTournament.TournamentId, roundNumber, tournamentMatchId, resultForPlayerA, out var errorMessage))
        {
            await Tracker.PersistAsync(JS);
            LoadTournamentState();
            Snackbar.Add("Tournament match result saved.", Severity.Success);
        }
        else
        {
            Snackbar.Add(errorMessage, Severity.Error);
        }
    }

    private async Task GenerateNextRoundAsync()
    {
        if (_currentTournament is null)
        {
            return;
        }

        var currentRound = GetCurrentRound(_currentTournament);
        if (currentRound is null)
        {
            Snackbar.Add("No current round found.", Severity.Error);
            return;
        }

        if (!IsRoundComplete(currentRound))
        {
            Snackbar.Add("Complete every match in the current round before generating a new one.", Severity.Warning);
            return;
        }

        if (_currentTournament.Rounds.Max(round => round.RoundNumber) != currentRound.RoundNumber)
        {
            Snackbar.Add("Play the already generated rounds before adding another one.", Severity.Warning);
            return;
        }

        var reseededPlayers = BuildSeededPlayersFromStandings(_currentTournament, _standings);
        var nextRound = BuildNextRound(_currentTournament, reseededPlayers, DateTime.UtcNow);
        if (nextRound is null || nextRound.Matches.Count == 0)
        {
            Snackbar.Add("No additional round can be generated for this tournament.", Severity.Info);
            return;
        }

        var updatedTournament = Tracker.GetCurrentTournamentSnapshot();
        if (updatedTournament is null || updatedTournament.TournamentId != _currentTournament.TournamentId)
        {
            Snackbar.Add("The active tournament changed. Reload and try again.", Severity.Error);
            LoadTournamentState();
            return;
        }

        updatedTournament.Seeds = reseededPlayers;
        updatedTournament.Rounds = updatedTournament.Rounds
            .OrderBy(round => round.RoundNumber)
            .ToList();
        updatedTournament.Rounds.Add(nextRound);
        updatedTournament.CompletedOnUtc = null;

        Tracker.SetCurrentTournamentSnapshot(updatedTournament);
        await Tracker.PersistAsync(JS);
        LoadTournamentState();
        Snackbar.Add($"Round {nextRound.RoundNumber} generated.", Severity.Success);
    }

    private async Task FinishTournamentAsync()
    {
        if (_currentTournament is null)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            title: "Finish Tournament",
            message: "Archive the current tournament without creating a new one? Its recorded tournament matches will remain in the overall dataset.",
            yesText: "Finish",
            noText: "Cancel",
            options: new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseOnEscapeKey = true
            });

        if (confirmed != true)
        {
            return;
        }

        Tracker.SetCurrentTournamentSnapshot(null);
        await Tracker.PersistAsync(JS);
        LoadTournamentState();
        Snackbar.Add("Tournament archived.", Severity.Info);
    }

    private async Task DiscardTournamentAsync()
    {
        if (_currentTournament is null)
        {
            return;
        }

        var confirmed = await DialogService.ShowMessageBox(
            title: "Discard Tournament",
            message: "Delete the active tournament and all matches recorded for it? This does not archive the tournament and cannot be undone.",
            yesText: "Discard",
            noText: "Cancel",
            options: new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseOnEscapeKey = true
            });

        if (confirmed != true)
        {
            return;
        }

        if (Tracker.TryDiscardCurrentTournament(out var removedMatchCount, out var errorMessage))
        {
            await Tracker.PersistAsync(JS);
            LoadTournamentState();
            Snackbar.Add($"Tournament discarded. Removed {removedMatchCount} associated matches.", Severity.Warning);
        }
        else
        {
            Snackbar.Add(errorMessage, Severity.Error);
        }
    }

    private async Task ConfirmDeleteArchivedTournamentAsync(TournamentHistorySummary tournament)
    {
        var confirmed = await DialogService.ShowMessageBox(
            title: "Delete Archived Tournament",
            message: $"Delete the {GetMatchingModeLabel(tournament.MatchingMode)} tournament archived on {tournament.ArchivedOnUtc.ToLocalTime():g}? This also removes all recorded matches from that tournament from the overall dataset and updates standings/statistics.",
            yesText: "Delete",
            noText: "Cancel",
            options: new DialogOptions
            {
                MaxWidth = MaxWidth.Small,
                FullWidth = true,
                CloseOnEscapeKey = true
            });

        if (confirmed != true)
        {
            return;
        }

        if (Tracker.TryDeleteArchivedTournament(tournament.TournamentId, out var removedMatchCount, out var errorMessage))
        {
            await Tracker.PersistAsync(JS);
            LoadTournamentState();
            Snackbar.Add($"Archived tournament deleted. Removed {removedMatchCount} recorded matches.", Severity.Info);
        }
        else
        {
            Snackbar.Add(errorMessage, Severity.Error);
        }
    }

    private void HandleArchivedTournamentRowClick(TableRowClickEventArgs<TournamentHistorySummary> args)
    {
        if (args.Item is null)
        {
            return;
        }

        ToggleArchivedTournamentExpansion(args.Item.TournamentId);
    }

    private void ToggleArchivedTournamentExpansion(Guid tournamentId)
    {
        if (!_expandedArchivedTournamentIds.Add(tournamentId))
        {
            _expandedArchivedTournamentIds.Remove(tournamentId);
        }
    }

    private static List<TournamentRoundSnapshot> BuildRounds(
        TournamentMatchingMode matchingMode,
        IReadOnlyList<TournamentSeedSnapshot> seededPlayers,
        DateTime generatedOnUtc)
    {
        var tournament = new TournamentSnapshot
        {
            TournamentId = Guid.NewGuid(),
            MatchingMode = matchingMode,
            GeneratedOnUtc = generatedOnUtc,
            Seeds = seededPlayers.Select(seed => seed with { }).ToList(),
            Rounds = new List<TournamentRoundSnapshot>()
        };

        var firstRound = BuildNextRound(tournament, seededPlayers, generatedOnUtc);
        if (matchingMode == TournamentMatchingMode.Knockout)
        {
            return BuildKnockoutRounds(seededPlayers, generatedOnUtc);
        }

        return firstRound is null
            ? new List<TournamentRoundSnapshot>()
            : new List<TournamentRoundSnapshot> { firstRound };
    }

    private IReadOnlyList<TournamentSeedSnapshot> GetSeededPlayers(TournamentRankMetric rankMetric)
    {
        var summaries = Tracker.GetPlayerSummaries();
        if (rankMetric == TournamentRankMetric.Random)
        {
            return summaries
                .OrderBy(_ => Random.Shared.Next())
                .Select((summary, index) =>
                    new TournamentSeedSnapshot(
                        index + 1,
                        summary.PlayerId,
                        summary.Name,
                        0,
                        0,
                        0,
                        PlayerSummary.StartingScore,
                        BuildWinRateLabel(0, 0, 0)))
                .ToList();
        }

        IEnumerable<PlayerSummary> sorted = rankMetric switch
        {
            TournamentRankMetric.TotalWins => summaries
                .OrderByDescending(summary => summary.Wins)
                .ThenByDescending(summary => summary.WinRate)
                .ThenByDescending(summary => summary.Score)
                .ThenBy(summary => summary.Name, StringComparer.OrdinalIgnoreCase)
                .ThenBy(summary => summary.Name, StringComparer.Ordinal),
            TournamentRankMetric.Points => summaries
                .OrderByDescending(summary => summary.Score)
                .ThenByDescending(summary => summary.WinRate)
                .ThenByDescending(summary => summary.Wins)
                .ThenBy(summary => summary.Name, StringComparer.OrdinalIgnoreCase)
                .ThenBy(summary => summary.Name, StringComparer.Ordinal),
            _ => summaries
                .OrderByDescending(summary => summary.WinRate)
                .ThenByDescending(summary => summary.Wins)
                .ThenByDescending(summary => summary.Score)
                .ThenBy(summary => summary.Name, StringComparer.OrdinalIgnoreCase)
                .ThenBy(summary => summary.Name, StringComparer.Ordinal)
        };

        return sorted.Select((summary, index) =>
                new TournamentSeedSnapshot(
                    index + 1,
                    summary.PlayerId,
                    summary.Name,
                    summary.Wins,
                    summary.Losses,
                    summary.Draws,
                    summary.Score,
                    summary.WinRateLabel))
            .ToList();
    }

    private static List<TournamentMatchSnapshot> BuildClassicSwissRound(
        IReadOnlyList<TournamentSeedSnapshot> seededPlayers,
        DateTime generatedOnUtc)
    {
        var matches = new List<TournamentMatchSnapshot>();
        if (seededPlayers.Count == 0)
        {
            return matches;
        }

        var topHalfSize = (seededPlayers.Count + 1) / 2;

        for (var i = 0; i < topHalfSize; i++)
        {
            var playerA = seededPlayers[i];
            var playerBIndex = i + topHalfSize;
            var playerB = playerBIndex < seededPlayers.Count ? seededPlayers[playerBIndex] : null;

            matches.Add(BuildMatch(i + 1, playerA, playerB, generatedOnUtc));
        }

        return matches;
    }

    private static List<TournamentRoundSnapshot> BuildKnockoutRounds(
        IReadOnlyList<TournamentSeedSnapshot> seededPlayers,
        DateTime generatedOnUtc)
    {
        var rounds = new List<TournamentRoundSnapshot>();
        if (seededPlayers.Count == 0)
        {
            return rounds;
        }

        if (seededPlayers.Count == 1)
        {
            rounds.Add(new TournamentRoundSnapshot
            {
                RoundNumber = 1,
                Matches = new List<TournamentMatchSnapshot>
                {
                    BuildMatch(1, seededPlayers[0], null, generatedOnUtc, "Final")
                }
            });

            return rounds;
        }

        var bracketSize = 1;
        while (bracketSize < seededPlayers.Count)
        {
            bracketSize *= 2;
        }

        var mainRoundCount = (int)Math.Log2(bracketSize);
        var orderedSeeds = BuildKnockoutSeedOrder(bracketSize);
        var seededBySeed = seededPlayers.ToDictionary(seed => seed.Seed);
        var roundOneMatches = new List<TournamentMatchSnapshot>();

        for (var i = 0; i < orderedSeeds.Count; i += 2)
        {
            seededBySeed.TryGetValue(orderedSeeds[i], out var playerA);
            seededBySeed.TryGetValue(orderedSeeds[i + 1], out var playerB);
            if (playerA is null && playerB is null)
            {
                continue;
            }

            playerA ??= playerB!;
            playerB = playerA == playerB ? null : playerB;

            roundOneMatches.Add(BuildMatch(
                roundOneMatches.Count + 1,
                playerA,
                playerB,
                generatedOnUtc,
                GetKnockoutMatchLabel(mainRoundCount, 1, roundOneMatches.Count + 1, orderedSeeds.Count / 2)));
        }

        rounds.Add(new TournamentRoundSnapshot
        {
            RoundNumber = 1,
            Matches = roundOneMatches
        });

        for (var roundNumber = 2; roundNumber <= mainRoundCount; roundNumber++)
        {
            var matches = new List<TournamentMatchSnapshot>();
            var isFinalRound = roundNumber == mainRoundCount;
            var previousRound = rounds[roundNumber - 2].Matches;
            var standardMatchCount = Math.Max(1, previousRound.Count / 2);

            for (var tableNumber = 1; tableNumber <= standardMatchCount; tableNumber++)
            {
                var sourceA = previousRound[(tableNumber - 1) * 2];
                var sourceB = previousRound[Math.Min(previousRound.Count - 1, ((tableNumber - 1) * 2) + 1)];

                matches.Add(BuildPendingKnockoutMatch(
                    tableNumber,
                    GetKnockoutMatchLabel(mainRoundCount, roundNumber, tableNumber, standardMatchCount),
                    sourceA.MatchId,
                    TournamentMatchParticipantSourceType.Winner,
                    sourceB.MatchId,
                    TournamentMatchParticipantSourceType.Winner));
            }

            if (isFinalRound && seededPlayers.Count >= 4 && previousRound.Count >= 2)
            {
                matches.Add(BuildPendingKnockoutMatch(
                    matches.Count + 1,
                    "Third Place",
                    previousRound[0].MatchId,
                    TournamentMatchParticipantSourceType.Loser,
                    previousRound[1].MatchId,
                    TournamentMatchParticipantSourceType.Loser));
            }

            rounds.Add(new TournamentRoundSnapshot
            {
                RoundNumber = roundNumber,
                Matches = matches
            });
        }

        return rounds;
    }

    private static List<int> BuildKnockoutSeedOrder(int bracketSize)
    {
        if (bracketSize <= 1)
        {
            return new List<int> { 1 };
        }

        var seeds = new List<int> { 1, 2 };
        while (seeds.Count < bracketSize)
        {
            var nextSize = seeds.Count * 2;
            var expanded = new List<int>(nextSize);
            foreach (var seed in seeds)
            {
                expanded.Add(seed);
                expanded.Add(nextSize + 1 - seed);
            }

            seeds = expanded;
        }

        return seeds;
    }

    private static TournamentMatchSnapshot BuildPendingKnockoutMatch(
        int tableNumber,
        string label,
        Guid playerASourceMatchId,
        TournamentMatchParticipantSourceType playerASourceType,
        Guid playerBSourceMatchId,
        TournamentMatchParticipantSourceType playerBSourceType)
    {
        return new TournamentMatchSnapshot
        {
            MatchId = Guid.NewGuid(),
            TableNumber = tableNumber,
            MatchLabel = label,
            PlayerASeed = 0,
            PlayerAId = Guid.Empty,
            PlayerAName = BuildPendingParticipantLabel(playerASourceType, playerASourceMatchId),
            PlayerASourceMatchId = playerASourceMatchId,
            PlayerASourceType = playerASourceType,
            PlayerBSeed = null,
            PlayerBId = null,
            PlayerBName = BuildPendingParticipantLabel(playerBSourceType, playerBSourceMatchId),
            PlayerBSourceMatchId = playerBSourceMatchId,
            PlayerBSourceType = playerBSourceType,
            IsBye = false,
            ResultForPlayerA = null,
            ReportedOnUtc = null,
            RecordedMatchId = null
        };
    }

    private static string BuildPendingParticipantLabel(
        TournamentMatchParticipantSourceType sourceType,
        Guid sourceMatchId)
    {
        _ = sourceMatchId;

        return sourceType == TournamentMatchParticipantSourceType.Winner
            ? "Winner TBD"
            : "Loser TBD";
    }

    private static string GetKnockoutMatchLabel(int mainRoundCount, int roundNumber, int matchNumber, int matchCountInRound)
    {
        if (roundNumber == mainRoundCount)
        {
            return matchCountInRound == 1 ? "Final" : $"Final {matchNumber}";
        }

        var remainingPlayerCount = (int)Math.Pow(2, mainRoundCount - roundNumber + 1);
        var baseLabel = remainingPlayerCount switch
        {
            4 => "Semifinal",
            8 => "Quarterfinal",
            _ => $"Round of {remainingPlayerCount}"
        };

        return matchCountInRound > 1
            ? $"{baseLabel} {matchNumber}"
            : baseLabel;
    }

    private static List<(TournamentSeedSnapshot PlayerA, TournamentSeedSnapshot PlayerB)> PairMonradRound(
        IReadOnlyList<TournamentSeedSnapshot> players,
        IReadOnlyDictionary<Guid, HashSet<Guid>> previousOpponents)
    {
        var pairs = new List<(TournamentSeedSnapshot PlayerA, TournamentSeedSnapshot PlayerB)>();
        var used = new HashSet<Guid>();

        foreach (var player in players)
        {
            if (!used.Add(player.PlayerId))
            {
                continue;
            }

            var opponent = players
                .Where(candidate => !used.Contains(candidate.PlayerId) && candidate.PlayerId != player.PlayerId)
                .OrderBy(candidate => previousOpponents[player.PlayerId].Contains(candidate.PlayerId) ? 1 : 0)
                .ThenBy(candidate => Math.Abs(candidate.Seed - player.Seed))
                .ThenBy(candidate => candidate.Seed)
                .FirstOrDefault();

            if (opponent is null)
            {
                continue;
            }

            used.Add(opponent.PlayerId);
            pairs.Add((player, opponent));

            previousOpponents[player.PlayerId].Add(opponent.PlayerId);
            previousOpponents[opponent.PlayerId].Add(player.PlayerId);
        }

        return pairs;
    }

    private static int GetSwissRoundCount(int playerCount)
    {
        if (playerCount <= 1)
        {
            return 1;
        }

        return (int)Math.Ceiling(Math.Log2(playerCount));
    }

    private static TournamentRoundSnapshot? BuildNextRound(
        TournamentSnapshot tournament,
        IReadOnlyList<TournamentSeedSnapshot> seededPlayers,
        DateTime generatedOnUtc)
    {
        if (seededPlayers.Count == 0)
        {
            return null;
        }

        var nextRoundNumber = tournament.Rounds.Count == 0
            ? 1
            : tournament.Rounds.Max(round => round.RoundNumber) + 1;

        var matches = tournament.MatchingMode switch
        {
            TournamentMatchingMode.Knockout => new List<TournamentMatchSnapshot>(),
            TournamentMatchingMode.RoundRobin => BuildRoundRobinRound(seededPlayers, BuildPreviousOpponents(tournament), BuildByeHistory(tournament), generatedOnUtc),
            TournamentMatchingMode.MonradSwiss => BuildMonradRound(seededPlayers, BuildPreviousOpponents(tournament), BuildByeHistory(tournament), generatedOnUtc),
            _ => BuildClassicSwissRound(seededPlayers, generatedOnUtc)
        };

        return matches.Count == 0
            ? null
            : new TournamentRoundSnapshot
            {
                RoundNumber = nextRoundNumber,
                Matches = matches
            };
    }

    private static List<TournamentMatchSnapshot> BuildMonradRound(
        IReadOnlyList<TournamentSeedSnapshot> seededPlayers,
        IReadOnlyDictionary<Guid, HashSet<Guid>> previousOpponents,
        IReadOnlyDictionary<Guid, bool> hasBye,
        DateTime generatedOnUtc)
    {
        var ordered = seededPlayers.ToList();
        TournamentSeedSnapshot? byePlayer = null;

        if (ordered.Count % 2 != 0)
        {
            byePlayer = ordered.LastOrDefault(seed => !hasBye.GetValueOrDefault(seed.PlayerId))
                ?? ordered[^1];
            ordered.Remove(byePlayer);
        }

        var pairs = PairMonradRound(ordered, previousOpponents);
        var matches = new List<TournamentMatchSnapshot>();
        var tableNumber = 1;

        foreach (var pair in pairs)
        {
            matches.Add(BuildMatch(tableNumber, pair.PlayerA, pair.PlayerB, generatedOnUtc));
            tableNumber++;
        }

        if (byePlayer is not null)
        {
            matches.Add(BuildMatch(tableNumber, byePlayer, null, generatedOnUtc));
        }

        return matches;
    }

    private static List<TournamentMatchSnapshot> BuildRoundRobinRound(
        IReadOnlyList<TournamentSeedSnapshot> seededPlayers,
        IReadOnlyDictionary<Guid, HashSet<Guid>> previousOpponents,
        IReadOnlyDictionary<Guid, bool> hasBye,
        DateTime generatedOnUtc)
    {
        var ordered = seededPlayers.ToList();
        TournamentSeedSnapshot? byePlayer = null;

        if (ordered.Count % 2 != 0)
        {
            byePlayer = ordered.LastOrDefault(seed => !hasBye.GetValueOrDefault(seed.PlayerId))
                ?? ordered[^1];
            ordered.Remove(byePlayer);
        }

        if (!TryCreateUniquePairs(ordered, previousOpponents, out var pairs))
        {
            return new List<TournamentMatchSnapshot>();
        }

        var matches = new List<TournamentMatchSnapshot>();
        var tableNumber = 1;

        foreach (var pair in pairs)
        {
            matches.Add(BuildMatch(tableNumber, pair.PlayerA, pair.PlayerB, generatedOnUtc));
            tableNumber++;
        }

        if (byePlayer is not null)
        {
            matches.Add(BuildMatch(tableNumber, byePlayer, null, generatedOnUtc));
        }

        return matches;
    }

    private static bool TryCreateUniquePairs(
        IReadOnlyList<TournamentSeedSnapshot> players,
        IReadOnlyDictionary<Guid, HashSet<Guid>> previousOpponents,
        out List<(TournamentSeedSnapshot PlayerA, TournamentSeedSnapshot PlayerB)> pairs)
    {
        pairs = new List<(TournamentSeedSnapshot PlayerA, TournamentSeedSnapshot PlayerB)>();

        if (players.Count == 0)
        {
            return true;
        }

        var first = players[0];
        for (var i = 1; i < players.Count; i++)
        {
            var candidate = players[i];
            if (previousOpponents[first.PlayerId].Contains(candidate.PlayerId))
            {
                continue;
            }

            var remaining = players
                .Where((_, index) => index != 0 && index != i)
                .ToList();

            if (!TryCreateUniquePairs(remaining, previousOpponents, out var tailPairs))
            {
                continue;
            }

            pairs.Add((first, candidate));
            pairs.AddRange(tailPairs);
            return true;
        }

        return false;
    }

    private static Dictionary<Guid, HashSet<Guid>> BuildPreviousOpponents(TournamentSnapshot tournament)
    {
        var opponents = tournament.Seeds.ToDictionary(seed => seed.PlayerId, _ => new HashSet<Guid>());

        foreach (var match in tournament.Rounds.SelectMany(round => round.Matches))
        {
            if (match.IsBye || !match.PlayerBId.HasValue)
            {
                continue;
            }

            opponents[match.PlayerAId].Add(match.PlayerBId.Value);
            opponents[match.PlayerBId.Value].Add(match.PlayerAId);
        }

        return opponents;
    }

    private static Dictionary<Guid, bool> BuildByeHistory(TournamentSnapshot tournament)
    {
        var byeHistory = tournament.Seeds.ToDictionary(seed => seed.PlayerId, _ => false);

        foreach (var match in tournament.Rounds.SelectMany(round => round.Matches).Where(match => match.IsBye))
        {
            byeHistory[match.PlayerAId] = true;
        }

        return byeHistory;
    }

    private static TournamentMatchSnapshot BuildMatch(
        int tableNumber,
        TournamentSeedSnapshot playerA,
        TournamentSeedSnapshot? playerB,
        DateTime generatedOnUtc,
        string? matchLabel = null)
    {
        var isBye = playerB is null;

        return new TournamentMatchSnapshot
        {
            MatchId = Guid.NewGuid(),
            TableNumber = tableNumber,
            MatchLabel = matchLabel,
            PlayerASeed = playerA.Seed,
            PlayerAId = playerA.PlayerId,
            PlayerAName = playerA.Name,
            PlayerASourceMatchId = null,
            PlayerASourceType = null,
            PlayerBSeed = playerB?.Seed,
            PlayerBId = playerB?.PlayerId,
            PlayerBName = playerB?.Name,
            PlayerBSourceMatchId = null,
            PlayerBSourceType = null,
            IsBye = isBye,
            ResultForPlayerA = isBye ? MatchResult.Win : null,
            ReportedOnUtc = isBye ? generatedOnUtc : null,
            RecordedMatchId = null
        };
    }

    private static List<TournamentStandingRow> BuildStandings(TournamentSnapshot tournament)
    {
        var standingsByPlayer = tournament.Seeds
            .Select(seed => new TournamentStandingRow
            {
                Seed = seed.Seed,
                Name = seed.Name,
                PlayerId = seed.PlayerId
            })
            .ToDictionary(row => row.PlayerId, row => row);

        foreach (var match in tournament.Rounds
                     .OrderBy(round => round.RoundNumber)
                     .SelectMany(round => round.Matches.OrderBy(match => match.TableNumber)))
        {
            if (!standingsByPlayer.TryGetValue(match.PlayerAId, out var rowA))
            {
                continue;
            }

            if (match.IsBye)
            {
                rowA.Wins++;
                rowA.Points += 3;
                continue;
            }

            if (!match.PlayerBId.HasValue || !standingsByPlayer.TryGetValue(match.PlayerBId.Value, out var rowB) || !match.ResultForPlayerA.HasValue)
            {
                continue;
            }

            switch (match.ResultForPlayerA.Value)
            {
                case MatchResult.Win:
                    rowA.Wins++;
                    rowA.Points += 3;
                    rowB.Losses++;
                    break;
                case MatchResult.Loss:
                    rowA.Losses++;
                    rowB.Wins++;
                    rowB.Points += 3;
                    break;
                default:
                    rowA.Draws++;
                    rowB.Draws++;
                    rowA.Points++;
                    rowB.Points++;
                    break;
            }
        }

        var sorted = standingsByPlayer.Values
            .OrderByDescending(row => row.Points)
            .ThenByDescending(row => row.Wins)
            .ThenBy(row => row.Seed)
            .ToList();

        for (var i = 0; i < sorted.Count; i++)
        {
            sorted[i].Rank = i + 1;
        }

        return sorted;
    }

    private static bool IsPlayerAWinner(TournamentMatchSnapshot match)
    {
        return match.ResultForPlayerA == MatchResult.Win || match.IsBye;
    }

    private static bool IsPlayerBWinner(TournamentMatchSnapshot match)
    {
        return match.ResultForPlayerA == MatchResult.Loss;
    }

    private static Color GetResultChipColor(TournamentMatchSnapshot match)
    {
        if (match.IsBye)
        {
            return Color.Success;
        }

        return match.ResultForPlayerA switch
        {
            MatchResult.Win => Color.Success,
            MatchResult.Loss => Color.Error,
            MatchResult.Draw => Color.Warning,
            _ => Color.Default
        };
    }

    private static string GetResultLabel(TournamentMatchSnapshot match)
    {
        if (match.IsBye)
        {
            return $"{match.PlayerAName} receives a bye";
        }

        if (!IsMatchReadyToPlay(match))
        {
            return "Waiting for participants";
        }

        return match.ResultForPlayerA switch
        {
            MatchResult.Win => $"{match.PlayerAName} won",
            MatchResult.Loss => $"{match.PlayerBName} won",
            MatchResult.Draw => "Draw",
            _ => "Result pending"
        };
    }

    private static string GetMatchingModeLabel(TournamentMatchingMode matchingMode)
    {
        return matchingMode switch
        {
            TournamentMatchingMode.Knockout => "Knockout",
            TournamentMatchingMode.MonradSwiss => "Monrad Swiss",
            TournamentMatchingMode.RoundRobin => "Round Robin",
            _ => "Classic Swiss Stage"
        };
    }

    private static bool IsMatchReadyToPlay(TournamentMatchSnapshot match)
    {
        return match.IsBye || (HasResolvedPlayerA(match) && HasResolvedPlayerB(match));
    }

    private static bool HasResolvedPlayerA(TournamentMatchSnapshot match)
    {
        return match.PlayerAId != Guid.Empty && match.PlayerASeed > 0;
    }

    private static bool HasResolvedPlayerB(TournamentMatchSnapshot match)
    {
        return match.PlayerBId.HasValue && match.PlayerBId.Value != Guid.Empty && match.PlayerBSeed.HasValue && match.PlayerBSeed.Value > 0;
    }

    private static string GetPlayerBDisplayName(TournamentMatchSnapshot match)
    {
        return string.IsNullOrWhiteSpace(match.PlayerBName) ? "TBD" : match.PlayerBName!;
    }

    private static string GetRoundDisplayLabel(TournamentSnapshot tournament, TournamentRoundSnapshot round)
    {
        if (tournament.MatchingMode != TournamentMatchingMode.Knockout)
        {
            return $"Round {round.RoundNumber}";
        }

        var labels = round.Matches
            .Select(match => match.MatchLabel)
            .Where(label => !string.IsNullOrWhiteSpace(label))
            .Distinct(StringComparer.Ordinal)
            .ToList();

        return labels.Count switch
        {
            0 => $"Round {round.RoundNumber}",
            1 => $"Round {round.RoundNumber} · {labels[0]}",
            _ => $"Round {round.RoundNumber} · {string.Join(" / ", labels)}"
        };
    }

    private static string GetRankMetricLabel(TournamentRankMetric rankMetric)
    {
        return rankMetric switch
        {
            TournamentRankMetric.TotalWins => "Total Wins",
            TournamentRankMetric.Points => "Points",
            TournamentRankMetric.Random => "Random",
            _ => "Win Rate"
        };
    }

    private static string GetArchivedRoundSummary(TournamentRoundSnapshot round)
    {
        return string.Join(" | ", round.Matches
            .OrderBy(match => match.TableNumber)
            .Select(match =>
            {
                var prefix = string.IsNullOrWhiteSpace(match.MatchLabel)
                    ? $"Match {match.TableNumber}: "
                    : $"{match.MatchLabel}: ";

                return match.IsBye
                    ? $"{prefix}{match.PlayerAName} bye"
                    : $"{prefix}{match.PlayerAName} vs {match.PlayerBName} ({GetArchivedMatchOutcome(match)})";
            }));
    }

    private static string GetArchivedMatchOutcome(TournamentMatchSnapshot match)
    {
        if (!match.ResultForPlayerA.HasValue)
        {
            return "pending";
        }

        return match.ResultForPlayerA.Value switch
        {
            MatchResult.Win => $"{match.PlayerAName} won",
            MatchResult.Loss => $"{match.PlayerBName} won",
            _ => "draw"
        };
    }

    private static string GetArchivedFinalScoreSummary(TournamentHistorySummary tournament)
    {
        var scores = tournament.Rounds
            .SelectMany(round => round.Matches)
            .Aggregate(new Dictionary<Guid, ArchivedTournamentScoreRow>(), (rows, match) =>
            {
                if (!rows.TryGetValue(match.PlayerAId, out var rowA))
                {
                    rowA = new ArchivedTournamentScoreRow(match.PlayerAId, match.PlayerAName);
                    rows[match.PlayerAId] = rowA;
                }

                if (match.IsBye)
                {
                    rowA.Wins++;
                    rowA.Points += 3;
                    return rows;
                }

                if (!match.PlayerBId.HasValue)
                {
                    return rows;
                }

                if (!rows.TryGetValue(match.PlayerBId.Value, out var rowB))
                {
                    rowB = new ArchivedTournamentScoreRow(match.PlayerBId.Value, match.PlayerBName ?? "Unknown Player");
                    rows[match.PlayerBId.Value] = rowB;
                }

                if (!match.ResultForPlayerA.HasValue)
                {
                    return rows;
                }

                switch (match.ResultForPlayerA.Value)
                {
                    case MatchResult.Win:
                        rowA.Wins++;
                        rowA.Points += 3;
                        rowB.Losses++;
                        break;
                    case MatchResult.Loss:
                        rowA.Losses++;
                        rowB.Wins++;
                        rowB.Points += 3;
                        break;
                    default:
                        rowA.Draws++;
                        rowB.Draws++;
                        rowA.Points++;
                        rowB.Points++;
                        break;
                }

                return rows;
            })
            .Values
            .OrderByDescending(row => row.Points)
            .ThenByDescending(row => row.Wins)
            .ThenBy(row => row.Name, StringComparer.OrdinalIgnoreCase)
            .ThenBy(row => row.Name, StringComparer.Ordinal)
            .Select(row => $"{row.Name} {row.Points} pts")
            .ToList();

        return scores.Count == 0
            ? "No score data available."
            : string.Join(" | ", scores);
    }

    private static (bool CanGenerate, string? DisabledReason) EvaluateNewRoundAvailability(
        TournamentSnapshot tournament,
        IReadOnlyList<TournamentStandingRow> standings)
    {
        if (tournament.MatchingMode == TournamentMatchingMode.Knockout)
        {
            return (false, "Knockout brackets are pre-generated.");
        }

        var currentRound = GetCurrentRound(tournament);
        if (currentRound is null)
        {
            return (false, "No round is available.");
        }

        if (!IsRoundComplete(currentRound))
        {
            return (false, "Complete all matches in the current round first.");
        }

        if (tournament.Rounds.Max(round => round.RoundNumber) != currentRound.RoundNumber)
        {
            return (false, "Play the already generated future rounds first.");
        }

        var reseededPlayers = BuildSeededPlayersFromStandings(tournament, standings);
        var canGenerate = tournament.MatchingMode switch
        {
            TournamentMatchingMode.RoundRobin => CanBuildRoundRobinRound(tournament, reseededPlayers),
            _ => reseededPlayers.Count > 0
        };

        return canGenerate
            ? (true, null)
            : (false, "No additional round is available for this tournament.");
    }

    private static bool CanBuildRoundRobinRound(
        TournamentSnapshot tournament,
        IReadOnlyList<TournamentSeedSnapshot> seededPlayers)
    {
        var ordered = seededPlayers.ToList();
        var hasBye = BuildByeHistory(tournament);

        if (ordered.Count % 2 != 0)
        {
            var byePlayer = ordered.LastOrDefault(seed => !hasBye.GetValueOrDefault(seed.PlayerId))
                ?? ordered[^1];
            ordered.Remove(byePlayer);
        }

        return TryCreateUniquePairs(ordered, BuildPreviousOpponents(tournament), out _);
    }

    private static TournamentRoundSnapshot? GetCurrentRound(TournamentSnapshot tournament)
    {
        return tournament.Rounds
            .OrderBy(round => round.RoundNumber)
            .FirstOrDefault(round => round.Matches.Any(match => !match.IsBye && !match.ResultForPlayerA.HasValue))
            ?? tournament.Rounds
                .OrderBy(round => round.RoundNumber)
                .LastOrDefault();
    }

    private static bool IsRoundComplete(TournamentRoundSnapshot round)
    {
        return round.Matches.All(match => match.IsBye || match.ResultForPlayerA.HasValue);
    }

    private static List<TournamentSeedSnapshot> BuildSeededPlayersFromStandings(
        TournamentSnapshot tournament,
        IReadOnlyList<TournamentStandingRow> standings)
    {
        var seedLookup = tournament.Seeds.ToDictionary(seed => seed.PlayerId);

        return standings
            .OrderBy(row => row.Rank)
            .Select((row, index) =>
                new TournamentSeedSnapshot(
                    index + 1,
                    seedLookup[row.PlayerId].PlayerId,
                    row.Name,
                    row.Wins,
                    row.Losses,
                    row.Draws,
                    row.Points,
                    BuildWinRateLabel(row.Wins, row.Losses, row.Draws)))
            .ToList();
    }

    private static string BuildWinRateLabel(int wins, int losses, int draws)
    {
        var matchesPlayed = wins + losses + draws;
        if (matchesPlayed == 0)
        {
            return "0% WR";
        }

        var winRatePercent = (int)Math.Round((double)wins / matchesPlayed * 100, MidpointRounding.AwayFromZero);
        return $"{winRatePercent}% WR";
    }

    private sealed class TournamentStandingRow
    {
        public int Rank { get; set; }
        public int Seed { get; set; }
        public Guid PlayerId { get; set; }
        public string Name { get; set; } = string.Empty;
        public int Wins { get; set; }
        public int Losses { get; set; }
        public int Draws { get; set; }
        public int Points { get; set; }
    }

    private sealed class ArchivedTournamentScoreRow
    {
        public ArchivedTournamentScoreRow(Guid playerId, string name)
        {
            PlayerId = playerId;
            Name = name;
        }

        public Guid PlayerId { get; }
        public string Name { get; }
        public int Wins { get; set; }
        public int Losses { get; set; }
        public int Draws { get; set; }
        public int Points { get; set; }
    }
}
